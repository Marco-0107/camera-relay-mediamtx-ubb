# Puerto del backend.
PORT=3000

# URL de la Control API de MediaMTX (acceso interno al servidor).
# Modo Docker: http://mediamtx:9997
# Modo PM2:    http://127.0.0.1:9997
MEDIAMTX_API_URL=http://localhost:9997

# URL interna del servidor HLS de MediaMTX.
# El backend la usa para hacer de proxy hacia el navegador (GET /hls/*).
# No es necesario exponerla externamente.
# Modo Docker: http://mediamtx:8888
# Modo PM2:    http://127.0.0.1:8888
MEDIAMTX_HLS_INTERNAL_URL=http://127.0.0.1:8888

# URL RTSP pública, la que se muestra al usuario para abrir en VLC/ffplay/OBS.
# Debe apuntar al host y puerto accesibles desde los clientes.
MEDIAMTX_RTSP_PUBLIC_URL=rtsp://TU_IP_SERVIDOR:8554

# Origen permitido para CORS.
CORS_ORIGIN=*

# Solo aplica en modo Docker, donde el backend sirve el build del frontend
# como archivos estáticos. En modo PM2 no se usa.
# FRONTEND_DIR=/app/frontend
