# Puerto del backend.
PORT=3000

# URL de la Control API de MediaMTX.
# Modo Docker: http://mediamtx:9997 (nombre del servicio en docker-compose.yml)
# Modo PM2 (uni): http://127.0.0.1:9997 (mediamtx corre como proceso local)
MEDIAMTX_API_URL=http://localhost:9997

# URL pública del endpoint WebRTC/WHEP de MediaMTX, la que usará el navegador.
MEDIAMTX_WEBRTC_PUBLIC_URL=http://localhost:8889

# URL RTSP pública de MediaMTX, la que se ofrece para copiar y abrir en
# VLC/ffplay/OBS. Debe apuntar al host accesible por los clientes (puerto 8554).
MEDIAMTX_RTSP_PUBLIC_URL=rtsp://localhost:8554

# Origen permitido para CORS. En modo Docker el frontend se sirve desde el
# mismo origen del backend, así que '*' no causa problemas. En modo PM2 el
# frontend corre en otro puerto/host: poner ahí su URL completa.
CORS_ORIGIN=*

# Solo aplica en modo Docker, donde el backend sirve el build del frontend
# como archivos estáticos. En modo PM2 no se usa (el frontend corre su propio
# proceso con `vite preview`).
# FRONTEND_DIR=/app/frontend
